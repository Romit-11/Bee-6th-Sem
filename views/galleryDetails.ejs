<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Gallery Details - WanderWay</title>
  <link rel="stylesheet" href="/style.css">

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</head>
<body class="gallery-details-bg">

  <%- include("partials/navbar") %>

  <div class="details-container glass">

    <!-- Location -->
    <h2 class="details-title">
      <i class="fa-solid fa-location-dot"></i>
      <%= gallery.location %>
    </h2>

    <!-- Uploaded by -->
    <p class="uploaded-info">
      Uploaded by <strong><%= gallery.uploadedBy %></strong>
    </p>

    <!-- Images Grid -->
    <div class="details-gallery">
      <% gallery.images.forEach(img => { %>
        <div class="details-image">
          <img src="/uploads/<%= img %>" alt="Gallery Image">
        </div>
      <% }) %>
    </div>

    <!-- Back button -->
    <div class="back-btn-wrapper">
      <a href="/gallery" class="back-btn">
        ← Back to Gallery
      </a>
    </div>

  </div>

</body>
</html>
