<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>WanderWay - Gallery</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>

<body class="gallery-bg">

  <%- include("partials/navbar") %>

    <div class="container">
      <h2 class="page-title">Travel Memories Gallery</h2>

      <% if (user) { %>
        <!-- Upload multiple images + location -->
        <form class="upload-form" action="/gallery/upload" method="POST" enctype="multipart/form-data">
          <input type="text" name="location" placeholder="Location (e.g. Shimla, India)" required>
          <input type="file" name="images" accept="image/*" multiple required>
          <button type="submit" class="btn">Upload</button>
        </form>
        <% } else { %>
          <p class="login-prompt">
            <a href="/login">Login</a> to upload images.
          </p>
          <% } %>

            <!-- Gallery Cards -->
            <div class="gallery-grid">

              <% if (galleries && galleries.length> 0) { %>

                <% galleries.forEach(g=> { %>
                  <div class="gallery-item">

                    <a href="/gallery/<%= g._id %>">
                      <img src="/uploads/<%= g.images[0] %>" alt="Gallery cover">

                      <p class="location">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= g.location %>
                      </p>
                    </a>

                    <!-- DELETE BUTTON (only uploader) -->
                    <% if (user && user.username===g.uploadedBy) { %>
                      <form action="/gallery/delete/<%= g._id %>" method="POST">
                        <button type="submit" class="btn btn-danger">Delete</button>
                      </form>
                      <% } %>

                  </div>

                  <% }) %>

                    <% } else { %>
                      <p class="empty-msg">
                        No images yet. Be the first to share your travel story!
                      </p>
                      <% } %>

            </div>
    </div>

    <footer class="footer">
      <p>© 2025 WanderWay. All Rights Reserved.</p>
    </footer>

</body>

</html>