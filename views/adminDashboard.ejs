<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard-WanderWay</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; background: #f4f4f9; }
    h2, h3 { color: #333; }
    form input, form button { padding: 8px; margin: 5px; }
    .hotel-list { margin-top: 20px; }
    .hotel-item {
      background: white; padding: 12px; margin-bottom: 10px;
      border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      display: flex; justify-content: space-between; align-items: center;
    }
    .hotel-item span { font-weight: bold; }
    .hotel-item form { display: inline; }
    .delete-btn { background: crimson; color: white; border: none; padding: 6px 12px; cursor: pointer; border-radius: 5px; }
    .delete-btn:hover { background: darkred; }
  </style>
</head>
<body class="admin-bg">

  <div class="admin-overlay"></div>

  <div class="admin-container">

    <header class="admin-header">
      <h1>👑 Admin Dashboard</h1>
      <p>Welcome, <strong><%= admin.username %></strong></p>
      <a href="/admin/logout" class="logout-btn">Logout</a>
    </header>

    <!-- NAV -->
    <div class="admin-nav">
      <a href="/admin/users">👥 Users</a>
      <a href="/admin/blogs">📝 Blogs</a>
      <a href="/admin/galleries">🖼 Gallery</a>
      <a href="/admin/trending-list">🔥 Trending</a>
    </div>

    <!-- HOTELS -->
    <section class="admin-section">
      <h2>🏨 Manage Hotels</h2>

      <form action="/admin/hotels" method="POST" class="admin-form">
        <input type="text" name="name" placeholder="Hotel Name" required>
        <input type="text" name="location" placeholder="Location" required>
        <input type="number" name="price" placeholder="Price" required>
        <button type="submit">Add Hotel</button>
      </form>

      <div class="admin-grid">
        <% hotels.forEach(h => { %>
          <div class="admin-card">
            <h3><%= h.name %></h3>
            <p>📍 <%= h.location %></p>
            <p>💰 ₹<%= h.price %></p>

            <form action="/admin/hotels/delete/<%= h._id %>" method="POST">
              <button class="danger-btn">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- TRENDING -->
    <section class="admin-section">
      <h2>🔥 Trending Places</h2>

      <a href="/admin/add-trending" class="primary-btn">
        ➕ Add Trending Place
      </a>

      <div class="admin-grid">
        <% trending.forEach(p => { %>
          <div class="admin-card">
            <img src="/uploads/<%= p.images[0] %>" alt="">
            <h3><%= p.name %></h3>
            <p>📍 <%= p.location %></p>

            <form action="/admin/delete-trending/<%= p._id %>" method="POST">
              <button class="danger-btn">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </section>

  </div>
</body>

</html>
